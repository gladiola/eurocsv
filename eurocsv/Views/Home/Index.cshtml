@model eurocsv.Models.ConversionSessionViewModel
@{
    ViewData["Title"] = "EuroCSV – CSV Localization Converter";
}

<div class="row">
    <div class="col-lg-8">
        <div class="p-4 mb-4 bg-light rounded-3">
            <h1 class="display-5 fw-bold">📊 EuroCSV</h1>
            <p class="lead">Convert CSV files between international formatting conventions in seconds.</p>
            <p>Different countries use different conventions for CSV files — German files typically use a <strong>semicolon separator</strong>
               and a <strong>comma as the decimal point</strong>, while English files use a <strong>comma separator</strong> and a
               <strong>period as the decimal point</strong>. EuroCSV handles all these differences for you.</p>
            <a class="btn btn-primary btn-lg" asp-controller="Csv" asp-action="Convert">
                🔄 Convert a CSV File
            </a>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">📤 Upload</h5>
                        <p class="card-text text-muted">Upload your CSV file (up to 50 MB). Your file is processed in memory and never stored permanently.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">⚙️ Configure</h5>
                        <p class="card-text text-muted">Choose source and target locale conventions. Fine-tune delimiters, decimal separators, and more.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">📥 Download</h5>
                        <p class="card-text text-muted">Download your converted file. Initiate file deletion at any time — we never retain your data.</p>
                    </div>
                </div>
            </div>
        </div>

        <h2 class="h4 mb-3">Supported Locale Conventions</h2>
        <p class="text-muted">EuroCSV includes presets for @Model.AvailableLocales.Count locales:</p>
        <div class="table-responsive mb-4">
            <table class="table table-sm table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>Locale</th>
                        <th>Delimiter</th>
                        <th>Decimal</th>
                        <th>Thousands</th>
                        <th>Date Format</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var locale in Model.AvailableLocales)
                    {
                        <tr>
                            <td><strong>@locale.DisplayName</strong> <small class="text-muted">(@locale.CultureCode)</small></td>
                            <td><code>@(locale.FieldDelimiter == "," ? "comma (,)" : locale.FieldDelimiter == ";" ? "semicolon (;)" : locale.FieldDelimiter)</code></td>
                            <td><code>@locale.DecimalSeparator</code></td>
                            <td><code>@(string.IsNullOrEmpty(locale.ThousandSeparator) ? "none" : locale.ThousandSeparator == " " ? "space" : locale.ThousandSeparator)</code></td>
                            <td><code>@locale.DateFormat</code></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="col-lg-4">
        <!-- Right-side ad placeholder -->
        <div class="ad-sidebar text-center bg-light border rounded p-2 mb-4 sticky-top" style="top:20px; min-height:600px; display:flex; align-items:center; justify-content:center;">
            <!-- Google AdSense sidebar ad — replace with live ad unit -->
            <!--
            <ins class="adsbygoogle"
                 style="display:block; min-height:600px;"
                 data-ad-client="ca-pub-XXXXXXXXXXXXXXXX"
                 data-ad-slot="XXXXXXXXXX"
                 data-ad-format="auto"
                 data-full-width-responsive="true"></ins>
            <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
            -->
            <small class="text-muted">Advertisement</small>
        </div>
    </div>
</div>

