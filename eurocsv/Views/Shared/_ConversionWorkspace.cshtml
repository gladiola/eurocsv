@model eurocsv.Models.ConversionSessionViewModel

<div class="row" id="convert-workspace">
    <div class="col-lg-8">

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">
                <strong>Error:</strong> @Model.ErrorMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.SessionId))
        {
            <div class="card border-success mb-4">
                <div class="card-header bg-success text-white">
                    <strong>✅ @L["ConvertCompleteTitle"]</strong>
                </div>
                <div class="card-body">
                    <dl class="row mb-3">
                        <dt class="col-sm-4">@L["ConvertOriginalFile"]</dt>
                        <dd class="col-sm-8">@Model.OriginalFileName <small class="text-muted">(@String.Format("{0:F1}", Model.OriginalFileSizeBytes / 1024.0) KB)</small></dd>

                        <dt class="col-sm-4">@L["ConvertFromLocale"]</dt>
                        <dd class="col-sm-8">@Model.FromConvention?.DisplayName (@Model.Options.FromLocale)</dd>

                        <dt class="col-sm-4">@L["ConvertToLocale"]</dt>
                        <dd class="col-sm-8">@Model.ToConvention?.DisplayName (@Model.Options.ToLocale)</dd>

                        <dt class="col-sm-4">@L["ConvertConvertedSize"]</dt>
                        <dd class="col-sm-8">@String.Format("{0:F1}", Model.TransformedFileSizeBytes / 1024.0) KB</dd>
                    </dl>

                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <a asp-controller="Csv" asp-action="DownloadOriginal" asp-route-sessionId="@Model.SessionId"
                           class="btn btn-outline-secondary">
                            📥 @L["ConvertDownloadOriginal"]
                        </a>
                        <a asp-controller="Csv" asp-action="DownloadTransformed" asp-route-sessionId="@Model.SessionId"
                           class="btn btn-primary">
                            📥 @L["ConvertDownloadConverted"]
                        </a>
                    </div>

                    <hr />
                    <p class="text-muted small mb-2">
                        @L["ConvertDeleteFilesDesc"]
                    </p>
                    <form asp-controller="Csv" asp-action="Cleanup" method="post" class="d-inline">
                        <input type="hidden" name="sessionId" value="@Model.SessionId" />
                        <button type="submit" class="btn btn-outline-danger btn-sm"
                                data-confirm="@L["ConvertDeleteConfirm"]"
                                onclick="return confirm(this.getAttribute('data-confirm'))">
                            🗑️ @L["ConvertDeleteFiles"]
                        </button>
                    </form>
                </div>
            </div>
        }

        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">@L["ConvertUploadSection"]</h5>
            </div>
            <div class="card-body">
                <form asp-controller="Csv" asp-action="Upload" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div class="mb-4">
                        <label for="csvFile" class="form-label fw-bold">@L["ConvertCsvFile"] <span class="text-danger">*</span></label>
                        <input type="file" class="form-control" id="csvFile" name="csvFile" accept=".csv,.txt" required />
                        <div class="form-text">@L["ConvertCsvFileHelp"]</div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label for="FromLocale" class="form-label fw-bold">@L["ConvertSourceLocale"]</label>
                            <select class="form-select" id="FromLocale" name="FromLocale" onchange="updatePresetHints()">
                                @foreach (var locale in Model.AvailableLocales)
                                {
                                    <option value="@locale.CultureCode"
                                            data-delimiter="@locale.FieldDelimiter"
                                            data-decimal="@locale.DecimalSeparator"
                                            data-thousands="@locale.ThousandSeparator"
                                            selected="@(locale.CultureCode == Model.Options.FromLocale ? "selected" : null)">
                                        @locale.DisplayName (@locale.CultureCode)
                                    </option>
                                }
                            </select>
                            <div id="fromHint" class="form-text text-muted"></div>
                        </div>

                        <div class="col-md-6">
                            <label for="ToLocale" class="form-label fw-bold">@L["ConvertTargetLocale"]</label>
                            <select class="form-select" id="ToLocale" name="ToLocale" onchange="updatePresetHints()">
                                @foreach (var locale in Model.AvailableLocales)
                                {
                                    <option value="@locale.CultureCode"
                                            data-delimiter="@locale.FieldDelimiter"
                                            data-decimal="@locale.DecimalSeparator"
                                            data-thousands="@locale.ThousandSeparator"
                                            selected="@(locale.CultureCode == Model.Options.ToLocale ? "selected" : null)">
                                        @locale.DisplayName (@locale.CultureCode)
                                    </option>
                                }
                            </select>
                            <div id="toHint" class="form-text text-muted"></div>
                        </div>
                    </div>

                    <div class="card bg-light mb-4">
                        <div class="card-header">
                            <button class="btn btn-link collapsed p-0 text-dark fw-semibold text-decoration-none" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#advancedOptions"
                                    aria-expanded="false" aria-controls="advancedOptions">
                                ⚙️ @L["ConvertOptions"]
                            </button>
                        </div>
                        <div class="collapse" id="advancedOptions">
                            <div class="card-body">
                                <div class="row g-3 mb-3">
                                    <div class="col-md-4">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="ConvertDelimiter" name="ConvertDelimiter" value="true"
                                                   @(Model.Options.ConvertDelimiter ? "checked" : "") />
                                            <label class="form-check-label" for="ConvertDelimiter">@L["ConvertConvertDelimiter"]</label>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="ConvertDecimalSeparator" name="ConvertDecimalSeparator" value="true"
                                                   @(Model.Options.ConvertDecimalSeparator ? "checked" : "") />
                                            <label class="form-check-label" for="ConvertDecimalSeparator">@L["ConvertConvertDecimal"]</label>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="ConvertThousandSeparator" name="ConvertThousandSeparator" value="true"
                                                   @(Model.Options.ConvertThousandSeparator ? "checked" : "") />
                                            <label class="form-check-label" for="ConvertThousandSeparator">@L["ConvertConvertThousands"]</label>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-check form-switch d-flex align-items-center gap-2">
                                            <input class="form-check-input" type="checkbox" id="HandleTextQualifiers" name="HandleTextQualifiers" value="true"
                                                   @(Model.Options.HandleTextQualifiers ? "checked" : "") />
                                            <label class="form-check-label" for="HandleTextQualifiers">@L["ConvertHandleQualifiers"]</label>
                                            <button type="button" class="btn btn-sm btn-outline-secondary rounded-circle lh-1 px-2"
                                                    data-bs-toggle="tooltip" data-bs-placement="top"
                                                    title="@L["ConvertHandleQualifiersTooltip"]"
                                                    aria-label="@L["ConvertHandleQualifiersTooltip"]">
                                                ?
                                            </button>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="ConvertLineEndings" name="ConvertLineEndings" value="true"
                                                   @(Model.Options.ConvertLineEndings ? "checked" : "") />
                                            <label class="form-check-label" for="ConvertLineEndings">@L["ConvertConvertLineEndings"]</label>
                                        </div>
                                    </div>
                                    <div class="col-md-4" id="lineEndingGroup">
                                        <label for="OutputLineEnding" class="form-label small">@L["ConvertOutputLineEnding"]</label>
                                        <select class="form-select form-select-sm" id="OutputLineEnding" name="OutputLineEnding">
                                            <option value="CRLF" selected="@(Model.Options.OutputLineEnding == "CRLF" ? "selected" : null)">@L["ConvertCRLF"]</option>
                                            <option value="LF" selected="@(Model.Options.OutputLineEnding == "LF" ? "selected" : null)">@L["ConvertLF"]</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="d-flex align-items-center gap-2 mt-3">
                                    <h6 class="mb-0">@L["ConvertCustomOverride"]</h6>
                                    <button type="button" class="btn btn-sm btn-outline-secondary rounded-circle lh-1 px-2"
                                            data-bs-toggle="tooltip" data-bs-placement="top"
                                            title="@L["ConvertCustomOverrideTooltip"]"
                                            aria-label="@L["ConvertCustomOverrideTooltip"]">
                                        ?
                                    </button>
                                </div>
                                <div class="row g-2 mt-1">
                                    <div class="col-md-2">
                                        <label class="form-label small">@L["ConvertFromDelimiter"]</label>
                                        <input type="text" class="form-control form-control-sm" name="CustomFromDelimiter"
                                               value="@Model.Options.CustomFromDelimiter" maxlength="3" />
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label small">@L["ConvertToDelimiter"]</label>
                                        <input type="text" class="form-control form-control-sm" name="CustomToDelimiter"
                                               value="@Model.Options.CustomToDelimiter" maxlength="3" />
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label small">@L["ConvertFromDecimal"]</label>
                                        <input type="text" class="form-control form-control-sm" name="CustomFromDecimal"
                                               value="@Model.Options.CustomFromDecimal" maxlength="1" />
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label small">@L["ConvertToDecimal"]</label>
                                        <input type="text" class="form-control form-control-sm" name="CustomToDecimal"
                                               value="@Model.Options.CustomToDecimal" maxlength="1" />
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label small">@L["ConvertFromThousands"]</label>
                                        <input type="text" class="form-control form-control-sm" name="CustomFromThousands"
                                               value="@Model.Options.CustomFromThousands" maxlength="1" />
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label small">@L["ConvertToThousands"]</label>
                                        <input type="text" class="form-control form-control-sm" name="CustomToThousands"
                                               value="@Model.Options.CustomToThousands" maxlength="1" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg">
                        🔄 @L["ConvertNow"]
                    </button>
                </form>
            </div>
        </div>

        <h2 class="h4 mb-3">@L["IndexSupportedLocales"]</h2>
        <p class="text-muted">EuroCSV includes presets for @Model.AvailableLocales.Count locales:</p>
        <div class="table-responsive mb-4">
            <table class="table table-sm table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>@L["TableLocale"]</th>
                        <th>@L["TableDelimiter"]</th>
                        <th>@L["TableDecimal"]</th>
                        <th>@L["TableThousands"]</th>
                        <th>@L["TableDateFormat"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var locale in Model.AvailableLocales)
                    {
                        <tr>
                            <td><strong>@locale.DisplayName</strong> <small class="text-muted">(@locale.CultureCode)</small></td>
                            <td><code>@(locale.FieldDelimiter == "," ? "comma (,)" : locale.FieldDelimiter == ";" ? "semicolon (;)" : locale.FieldDelimiter)</code></td>
                            <td><code>@locale.DecimalSeparator</code></td>
                            <td><code>@(string.IsNullOrEmpty(locale.ThousandSeparator) ? "none" : locale.ThousandSeparator == " " ? "space" : locale.ThousandSeparator)</code></td>
                            <td><code>@locale.DateFormat</code></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-info">
            <div class="card-header bg-info bg-opacity-10">
                <strong>ℹ️ @L["HowItWorksTitle"]</strong>
            </div>
            <div class="card-body small">
                @Html.Raw(L["HowItWorksBody"].Value)
            </div>
        </div>
    </div>
</div>

<script nonce="@Context.Items["Nonce"]">
        const sel = document.getElementById(selectId);
        return sel ? sel.options[sel.selectedIndex] : null;
    }

    function formatHint(opt) {
        if (!opt) return '';
        const delim = opt.getAttribute('data-delimiter');
        const dec = opt.getAttribute('data-decimal');
        const thou = opt.getAttribute('data-thousands');
        const delimLabel = delim === ',' ? 'comma' : delim === ';' ? 'semicolon' : delim;
        const thouLabel = thou === '' ? 'none' : thou === ' ' ? 'space' : thou;
        return `Delimiter: <code>${delimLabel}</code>, Decimal: <code>${dec}</code>, Thousands: <code>${thouLabel}</code>`;
    }

    function updatePresetHints() {
        const fromOpt = getSelectedOption('FromLocale');
        const toOpt = getSelectedOption('ToLocale');
        const fromHint = document.getElementById('fromHint');
        const toHint = document.getElementById('toHint');

        if (fromHint) {
            fromHint.innerHTML = formatHint(fromOpt);
        }

        if (toHint) {
            toHint.innerHTML = formatHint(toOpt);
        }
    }

    function initializeConversionWorkspace() {
        updatePresetHints();
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach((element) => {
            bootstrap.Tooltip.getOrCreateInstance(element);
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initializeConversionWorkspace, { once: true });
    } else {
        initializeConversionWorkspace();
    }
</script>
