<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EuroCSV</title>
    <script type="importmap" nonce="@Context.Items["Nonce"]"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/eurocsv.styles.css" asp-append-version="true" />

</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-primary border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    📊 EuroCSV
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="@L["NavToggleNavigation"]">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index">@L["NavHome"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index" asp-fragment="convert-workspace">@L["NavConvertCsv"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Privacy">@L["NavPrivacy"]</a>
                        </li>
                    </ul>
                    <!-- Language switcher -->
                    <ul class="navbar-nav">
                        <li class="nav-item dropdown">
                            <a class="nav-link text-white dropdown-toggle" href="#" id="langDropdown" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                🌐 @L["LanguageSelect"]
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="langDropdown">
                                @{
                                    var cultures = new[]
                                    {
                                        ("en-US", "English (US)"),
                                        ("en-GB", "English (UK)"),
                                        ("de-DE", "Deutsch (DE)"),
                                        ("de-AT", "Deutsch (AT)"),
                                        ("de-CH", "Deutsch (CH)"),
                                        ("fr-FR", "Français (FR)"),
                                        ("fr-BE", "Français (BE)"),
                                        ("fr-CH", "Français (CH)"),
                                        ("es-ES", "Español (ES)"),
                                        ("es-MX", "Español (MX)"),
                                        ("it-IT", "Italiano"),
                                        ("nl-NL", "Nederlands (NL)"),
                                        ("nl-BE", "Nederlands (BE)"),
                                        ("pt-PT", "Português (PT)"),
                                        ("pt-BR", "Português (BR)"),
                                        ("pl-PL", "Polski"),
                                        ("cs-CZ", "Čeština"),
                                        ("sk-SK", "Slovenčina"),
                                        ("ru-RU", "Русский"),
                                        ("sv-SE", "Svenska"),
                                        ("da-DK", "Dansk"),
                                        ("nb-NO", "Norsk"),
                                        ("fi-FI", "Suomi"),
                                        ("hu-HU", "Magyar"),
                                        ("ro-RO", "Română"),
                                        ("tr-TR", "Türkçe"),
                                        ("ja-JP", "日本語"),
                                        ("zh-CN", "中文 (简体)"),
                                        ("el-GR", "Ελληνικά"),
                                        ("bg-BG", "Български"),
                                        ("hr-HR", "Hrvatski"),
                                        ("uk-UA", "Українська"),
                                        ("lt-LT", "Lietuvių"),
                                        ("lv-LV", "Latviešu"),
                                    };
                                    var returnUrl = Context.Request.Path + Context.Request.QueryString;
                                    foreach (var (code, label) in cultures)
                                    {
                                        <li>
                                            <form asp-controller="Culture" asp-action="SetCulture" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="culture" value="@code" />
                                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                <button type="submit" class="dropdown-item">@label</button>
                                            </form>
                                        </li>
                                    }
                                }
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Message"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container py-2">
            <div class="row">
                <div class="col-md-6">
                    @L["FooterCopyright"]
                </div>
                <div class="col-md-6 text-md-end">
                    <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-muted me-3">@L["FooterPrivacyPolicy"]</a>
                    <a asp-area="" asp-controller="Home" asp-action="Index" asp-fragment="convert-workspace" class="text-muted">@L["NavConvertCsv"]</a>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js" nonce="@Context.Items["Nonce"]"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" nonce="@Context.Items["Nonce"]"></script>
    <script src="~/js/site.js" asp-append-version="true" nonce="@Context.Items["Nonce"]"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
