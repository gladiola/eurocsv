@model eurocsv.Models.ConversionSessionViewModel
@using eurocsv.Models
@{
    ViewData["Title"] = "Convert CSV";
}

<h1 class="mb-3">🔄 Convert CSV File</h1>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger" role="alert">
        <strong>Error:</strong> @Model.ErrorMessage
    </div>
}

<div class="row">
    <div class="col-lg-8">

        @if (!string.IsNullOrEmpty(Model.SessionId))
        {
            <!-- Conversion complete panel -->
            <div class="card border-success mb-4">
                <div class="card-header bg-success text-white">
                    <strong>✅ Conversion Complete</strong>
                </div>
                <div class="card-body">
                    <dl class="row mb-3">
                        <dt class="col-sm-4">Original file</dt>
                        <dd class="col-sm-8">@Model.OriginalFileName <small class="text-muted">(@String.Format("{0:F1}", Model.OriginalFileSizeBytes / 1024.0) KB)</small></dd>

                        <dt class="col-sm-4">From locale</dt>
                        <dd class="col-sm-8">@Model.FromConvention?.DisplayName (@Model.Options.FromLocale)</dd>

                        <dt class="col-sm-4">To locale</dt>
                        <dd class="col-sm-8">@Model.ToConvention?.DisplayName (@Model.Options.ToLocale)</dd>

                        <dt class="col-sm-4">Converted file size</dt>
                        <dd class="col-sm-8">@String.Format("{0:F1}", Model.TransformedFileSizeBytes / 1024.0) KB</dd>
                    </dl>

                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <a asp-controller="Csv" asp-action="DownloadOriginal" asp-route-sessionId="@Model.SessionId"
                           class="btn btn-outline-secondary">
                            📥 Download Original
                        </a>
                        <a asp-controller="Csv" asp-action="DownloadTransformed" asp-route-sessionId="@Model.SessionId"
                           class="btn btn-primary">
                            📥 Download Converted File
                        </a>
                    </div>

                    <hr />
                    <p class="text-muted small mb-2">
                        Your files are stored temporarily on the server. Click the button below to delete them immediately,
                        or they will be automatically removed within 2 hours.
                    </p>
                    <form asp-controller="Csv" asp-action="Cleanup" method="post" class="d-inline">
                        <input type="hidden" name="sessionId" value="@Model.SessionId" />
                        <button type="submit" class="btn btn-outline-danger btn-sm"
                                onclick="return confirm('Delete your temporary files now? You will no longer be able to download them.')">
                            🗑️ Delete My Files Now
                        </button>
                    </form>
                </div>
            </div>
        }

        <!-- Upload & conversion form -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Upload &amp; Convert</h5>
            </div>
            <div class="card-body">
                <form asp-controller="Csv" asp-action="Upload" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <!-- File upload -->
                    <div class="mb-4">
                        <label for="csvFile" class="form-label fw-bold">CSV File <span class="text-danger">*</span></label>
                        <input type="file" class="form-control" id="csvFile" name="csvFile" accept=".csv,.txt" required />
                        <div class="form-text">Maximum file size: 50 MB. Accepted formats: .csv, .txt</div>
                    </div>

                    <div class="row g-3 mb-4">
                        <!-- From locale -->
                        <div class="col-md-6">
                            <label for="FromLocale" class="form-label fw-bold">Source Locale (From)</label>
                            <select class="form-select" id="FromLocale" name="FromLocale" onchange="updatePresetHints()">
                                @foreach (var locale in Model.AvailableLocales)
                                {
                                    <option value="@locale.CultureCode"
                                            data-delimiter="@locale.FieldDelimiter"
                                            data-decimal="@locale.DecimalSeparator"
                                            data-thousands="@locale.ThousandSeparator"
                                            selected="@(locale.CultureCode == Model.Options.FromLocale ? "selected" : null)">
                                        @locale.DisplayName (@locale.CultureCode)
                                    </option>
                                }
                            </select>
                            <div id="fromHint" class="form-text text-muted"></div>
                        </div>

                        <!-- To locale -->
                        <div class="col-md-6">
                            <label for="ToLocale" class="form-label fw-bold">Target Locale (To)</label>
                            <select class="form-select" id="ToLocale" name="ToLocale" onchange="updatePresetHints()">
                                @foreach (var locale in Model.AvailableLocales)
                                {
                                    <option value="@locale.CultureCode"
                                            data-delimiter="@locale.FieldDelimiter"
                                            data-decimal="@locale.DecimalSeparator"
                                            data-thousands="@locale.ThousandSeparator"
                                            selected="@(locale.CultureCode == Model.Options.ToLocale ? "selected" : null)">
                                        @locale.DisplayName (@locale.CultureCode)
                                    </option>
                                }
                            </select>
                            <div id="toHint" class="form-text text-muted"></div>
                        </div>
                    </div>

                    <!-- Transformation toggles -->
                    <div class="card bg-light mb-4">
                        <div class="card-header">
                            <button class="btn btn-link p-0 text-dark fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#advancedOptions">
                                ⚙️ Transformation Options
                            </button>
                        </div>
                        <div class="collapse show" id="advancedOptions">
                            <div class="card-body">
                                <div class="row g-3 mb-3">
                                    <div class="col-md-4">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="ConvertDelimiter" name="ConvertDelimiter" value="true"
                                                   @(Model.Options.ConvertDelimiter ? "checked" : "") />
                                            <label class="form-check-label" for="ConvertDelimiter">Convert field delimiter</label>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="ConvertDecimalSeparator" name="ConvertDecimalSeparator" value="true"
                                                   @(Model.Options.ConvertDecimalSeparator ? "checked" : "") />
                                            <label class="form-check-label" for="ConvertDecimalSeparator">Convert decimal separator</label>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="ConvertThousandSeparator" name="ConvertThousandSeparator" value="true"
                                                   @(Model.Options.ConvertThousandSeparator ? "checked" : "") />
                                            <label class="form-check-label" for="ConvertThousandSeparator">Convert thousands separator</label>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="HandleTextQualifiers" name="HandleTextQualifiers" value="true"
                                                   @(Model.Options.HandleTextQualifiers ? "checked" : "") />
                                            <label class="form-check-label" for="HandleTextQualifiers">Respect quoted fields</label>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="ConvertLineEndings" name="ConvertLineEndings" value="true"
                                                   @(Model.Options.ConvertLineEndings ? "checked" : "") />
                                            <label class="form-check-label" for="ConvertLineEndings">Convert line endings</label>
                                        </div>
                                    </div>
                                    <div class="col-md-4" id="lineEndingGroup">
                                        <label for="OutputLineEnding" class="form-label small">Output line endings</label>
                                        <select class="form-select form-select-sm" id="OutputLineEnding" name="OutputLineEnding">
                                            <option value="CRLF" selected="@(Model.Options.OutputLineEnding == "CRLF" ? "selected" : null)">CRLF (Windows)</option>
                                            <option value="LF" selected="@(Model.Options.OutputLineEnding == "LF" ? "selected" : null)">LF (Unix/Mac)</option>
                                        </select>
                                    </div>
                                </div>

                                <h6 class="mt-3">Custom Override (leave blank to use locale preset)</h6>
                                <div class="row g-2">
                                    <div class="col-md-2">
                                        <label class="form-label small">From delimiter</label>
                                        <input type="text" class="form-control form-control-sm" name="CustomFromDelimiter"
                                               value="@Model.Options.CustomFromDelimiter" maxlength="3" />
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label small">To delimiter</label>
                                        <input type="text" class="form-control form-control-sm" name="CustomToDelimiter"
                                               value="@Model.Options.CustomToDelimiter" maxlength="3" />
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label small">From decimal</label>
                                        <input type="text" class="form-control form-control-sm" name="CustomFromDecimal"
                                               value="@Model.Options.CustomFromDecimal" maxlength="1" />
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label small">To decimal</label>
                                        <input type="text" class="form-control form-control-sm" name="CustomToDecimal"
                                               value="@Model.Options.CustomToDecimal" maxlength="1" />
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label small">From thousands</label>
                                        <input type="text" class="form-control form-control-sm" name="CustomFromThousands"
                                               value="@Model.Options.CustomFromThousands" maxlength="1" />
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label small">To thousands</label>
                                        <input type="text" class="form-control form-control-sm" name="CustomToThousands"
                                               value="@Model.Options.CustomToThousands" maxlength="1" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg">
                        🔄 Convert Now
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <!-- Sidebar ad placeholder -->
        <div class="ad-sidebar text-center bg-light border rounded p-2 mb-4 sticky-top" style="top:20px; min-height:400px; display:flex; align-items:center; justify-content:center;">
            <!-- Google AdSense sidebar ad — replace with live ad unit -->
            <!--
            <ins class="adsbygoogle"
                 style="display:block; min-height:400px;"
                 data-ad-client="ca-pub-XXXXXXXXXXXXXXXX"
                 data-ad-slot="XXXXXXXXXX"
                 data-ad-format="auto"
                 data-full-width-responsive="true"></ins>
            <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
            -->
            <small class="text-muted">Advertisement</small>
        </div>

        <!-- Help card -->
        <div class="card border-info">
            <div class="card-header bg-info bg-opacity-10">
                <strong>ℹ️ How it works</strong>
            </div>
            <div class="card-body small">
                <p><strong>Delimiter</strong> — The character used to separate fields. German/European CSVs typically use <code>;</code> while English CSVs use <code>,</code>.</p>
                <p><strong>Decimal separator</strong> — The character used for decimal points. German: <code>1.234,56</code> → English: <code>1,234.56</code>.</p>
                <p><strong>Thousands separator</strong> — Only enable this if your file contains formatted numbers with thousands separators.</p>
                <p><strong>Quoted fields</strong> — Fields wrapped in quotes are protected from delimiter/separator substitution.</p>
                <p class="mb-0"><strong>Privacy</strong> — Your files are processed server-side and stored temporarily. Use the <em>Delete My Files</em> button to remove them immediately.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function getSelectedOption(selectId) {
        const sel = document.getElementById(selectId);
        return sel ? sel.options[sel.selectedIndex] : null;
    }

    function formatHint(opt) {
        if (!opt) return '';
        const delim = opt.getAttribute('data-delimiter');
        const dec = opt.getAttribute('data-decimal');
        const thou = opt.getAttribute('data-thousands');
        const delimLabel = delim === ',' ? 'comma' : delim === ';' ? 'semicolon' : delim;
        const thouLabel = thou === '' ? 'none' : thou === ' ' ? 'space' : thou;
        return `Delimiter: <code>${delimLabel}</code>, Decimal: <code>${dec}</code>, Thousands: <code>${thouLabel}</code>`;
    }

    function updatePresetHints() {
        const fromOpt = getSelectedOption('FromLocale');
        const toOpt = getSelectedOption('ToLocale');
        document.getElementById('fromHint').innerHTML = formatHint(fromOpt);
        document.getElementById('toHint').innerHTML = formatHint(toOpt);
    }

    // Run on page load
    updatePresetHints();
</script>
}
